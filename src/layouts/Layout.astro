---
import Sidebar from '../components/svelte/layout/Sidebar.svelte';
import '../assets/app.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
		<title>Material You Showcase</title>
	</head>
	<body class="md-surface">
		<Sidebar client:load />
		<div class="page">
			<header class="top-bar">
				<div class="top-bar-title">
					<span class="md-icon">adaptive_audio_mic</span>
					<span class="md-title-medium">Material You Showcase</span>
				</div>
				<div class="top-bar-actions">
					<button class="md-icon-btn">
						<span class="md-icon">search</span>
					</button>
					<button class="md-icon-btn">
						<span class="md-icon">notifications</span>
					</button>
					<div class="avatar">MY</div>
				</div>
			</header>
			<main class="content">
				<slot />
			</main>
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: 'Roboto', sans-serif;
	}
	.content {
		padding: 16px 24px 24px;
		min-height: 100vh;
	}

	.page {
		margin-left: 88px;
		min-height: 100vh;
		padding: 16px 24px;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.top-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 14px 20px;
		border-radius: 20px;
		background-color: var(--md-sys-color-surface-container);
		border: 1px solid var(--md-sys-color-outline-variant);
	}

	.top-bar-title {
		display: flex;
		align-items: center;
		gap: 10px;
		color: var(--md-sys-color-on-surface);
	}

	.top-bar-actions {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.top-bar .md-icon-btn {
		color: var(--md-sys-color-on-surface-variant);
	}

	.avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background-color: var(--md-sys-color-primary-container);
		color: var(--md-sys-color-on-primary-container);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 12px;
		font-weight: 600;
	}
</style>
